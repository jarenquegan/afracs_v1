# Copy to .env and adjust per deployment.

CAMERA_INDEX=0

CABINET_NAME=College of Health Cabinet

# Per-cabinet GPIO BCM pins — cabinet_id:pin, comma-separated.
# Must match the cabinet_id values seeded in the database (A, B, C, D).
CABINET_LOCK_PINS=A:17,B:18,C:19,D:20

# Single-lock fallback (ignored when CABINET_LOCK_PINS is set)
GPIO_LOCK_PIN=17
LOCK_PULSE_SECONDS=7.5

ALERT_AFTER_FAILED_ATTEMPTS=5

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=afracs

FLASK_HOST=0.0.0.0
FLASK_PORT=5000
